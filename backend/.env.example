# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://vikassuthar:Amrit1671vikas@cluster0.vius994.mongodb.net/api_monitor?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Slow API threshold (milliseconds)
SLOW_API_THRESHOLD_MS=500

# Email Alerts (Gmail SMTP — use App Password)
EMAIL_ENABLED=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=API Monitor <your_gmail@gmail.com>

# Slack Alerts
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# CORS origin (your frontend URL)
CLIENT_ORIGIN=http://localhost:5173

# AWS CloudWatch (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDWATCH_LOG_GROUP=/api-monitor/backend
